# ══════════════════════════════════════════════
# Gestor de Contraseñas Seguro - .gitignore
# ══════════════════════════════════════════════

# ── Bóveda cifrada (NUNCA subir a GitHub) ──
vault.enc

# ── Logs ──
logs/

# ── PyInstaller (compilación) ──
dist/
build/
*.spec

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
*.whl

# ── Entornos virtuales ──
venv/
env/
.venv/
.env/

# ── IDEs ──
.vscode/
.idea/
*.swp
*.swo
*~
.vs/

# ── OS ──
Thumbs.db
Desktop.ini
.DS_Store
